# Database Configuration
# Production: use port 5434 (magicdeckgen-postgres container)
DATABASE_URL=postgresql://magicdeckgen:magicdeckgen_dev@localhost:5434/magicdeckgen
# Use sqlite for local dev without Docker: sqlite:///data/magic.db
# DATABASE_URL=sqlite:///data/magic.db

# Brevo (ex Sendinblue) Configuration
BREVO_API_KEY=your-brevo-api-key-here
FROM_EMAIL=noreply@magicdeckbuilder.app
FROM_NAME=Magic Deck Builder

# Frontend URL
FRONTEND_URL=http://localhost:5173

# JWT Secret (change in production!)
SECRET_KEY=your-secret-key-change-in-production

